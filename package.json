{
  "name": "@coderych/naive-ui-pro-components",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@10.33.4",
  "description": "Advanced pro components built on top of Naive UI for Vue 3",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coderych/naive-ui-pro-components"
  },
  "keywords": [
    "vue",
    "vue3",
    "naive-ui",
    "pro-components",
    "table",
    "form",
    "tsx"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.js"
    },
    "./es/*": "./es/*",
    "./lib/*": "./lib/*"
  },
  "main": "./lib/index.js",
  "module": "./es/index.mjs",
  "types": "./es/index.d.ts",
  "web-types": "./web-types.json",
  "volar": "./volar.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "es",
    "lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir es",
    "build:lib": "npm run build && node scripts/post-build.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "rimraf es lib dist",
    "prepublishOnly": "npm run clean && npm run build:lib"
  },
  "peerDependencies": {
    "naive-ui": "^2.38.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@css-render/plugin-bem": "^0.15.14",
    "@iconify-icons/heroicons": "^1.2.9",
    "@iconify/vue": "^4.2.0",
    "css-render": "^0.15.14",
    "lodash-es": "^4.17.21",
    "vue-draggable-plus": "^0.6.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "naive-ui": "^2.40.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.3.2",
    "vitepress": "^1.6.3",
    "vitest": "^3.1.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  }
}
